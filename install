#!/usr/bin/env sh
# Quick install script
#
# Performs three steps in order:
#   1. Ensure a local servers.conf exists (copy it from servers.example.conf if missing)
#   2. Create a symlink in the user config directory pointing to the local servers.conf
#      (~/.config/sntp-synchronizer/servers.conf -> <project>/servers.conf)
#   3. Run cargo install --path . to install the global executable
#
# Usage: run ./install from the project root

set -eu

# Project root (the directory this script lives in)
SCRIPT_DIR=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
cd "$SCRIPT_DIR"

CONF="$SCRIPT_DIR/servers.conf"
EXAMPLE="$SCRIPT_DIR/servers.example.conf"
CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/sntp-synchronizer"
LINK="$CONFIG_DIR/servers.conf"

# 1. Ensure the local config file exists
if [ ! -f "$CONF" ]; then
    cp "$EXAMPLE" "$CONF"
    echo "Created config file from example: $CONF"
fi

# 2. Create the config directory and link the config file
mkdir -p "$CONFIG_DIR"

# If the link location already exists and is not a symlink, back it up first to avoid overwriting an existing real file
if [ -e "$LINK" ] && [ ! -L "$LINK" ]; then
    mv "$LINK" "$LINK.bak"
    echo "Backed up existing config file: $LINK -> $LINK.bak"
fi

ln -sfn "$CONF" "$LINK"
echo "Linked config file: $LINK -> $CONF"

# 3. Install the global executable
cargo install --path .
echo "Installation complete; run: sntp-synchronizer"
